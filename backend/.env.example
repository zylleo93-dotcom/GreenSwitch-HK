# GreenSwitch Backend Environment Variables

# Server
PORT=3001
LOG_LEVEL=info

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Firebase Admin Service Account (Base64 encoded JSON)
# 获取方式: cat serviceAccountKey.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional: Cloud Storage (for production)
# STORAGE_BUCKET=your-bucket-name
